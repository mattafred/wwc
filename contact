                                    </div>
                                </div>
                                <!-- Créneaux horaires -->
                                <div>
                                    <div style="font-size: 0.875rem; font-weight: 600; margin-bottom: 0.5rem; text-align: center;">Horaires Disponibles</div>
                                    <div class="time-slots">
                                        <div class="time-slot selected">10:00 AM</div>
                                        <div class="time-slot">11:30 AM</div>
                                        <div class="time-slot">2:00 PM</div>
                                        <div class="time-slot">4:00 PM</div>
                                    </div>
                                    <button class="btn btn-primary" style="width: 100%; margin-top: 1rem; border-radius: var(--radius-sm);">Réserver Maintenant</button>
                                </div>
                            </div>
                        </div>

                        <!-- Formulaire -->
                        <h3 style="font-size: 1.25rem; color: var(--text-main); margin-bottom: 1.5rem;">Envoyer une Demande</h3>
                        <form action="#" method="POST" onsubmit="event.preventDefault(); alert('Demande envoyée !');">
                            <div class="form-row">
                                <div class="form-group">
                                    <input type="text" class="form-control" placeholder="Nom Complet" required>
                                </div>
                                <div class="form-group">
                                    <input type="email" class="form-control" placeholder="Adresse Email" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <input type="text" class="form-control" placeholder="Nom de l'Entreprise (Optionnel)">
                            </div>
                            <div class="form-group">
                                <textarea class="form-control" placeholder="Message" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: var(--radius-sm);">Envoyer la Demande</button>
                        </form>
                    </div>
                </div>
            </div>
            
            <!-- Logo Footer section for this specific page to match mockup -->
            <div class="container" style="border-top: 1px solid var(--bg-alt); padding-top: 1.5rem; margin-bottom: 2rem; display: flex; justify-content: space-between; font-size: 0.875rem; color: var(--text-muted);">
