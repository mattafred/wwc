    <main>
        <section class="page-header" style="background: transparent; border: none; padding-bottom: 0;">
            <div class="container">
                <h1>Contact & Réservation</h1>
            </div>
        </section>

        <section>
            <div class="container">
                <div class="contact-card grid grid-cols-2">
                    
                    <!-- Colonne de gauche: Infos -->
                    <div>
                        <h2 style="font-size: 1.5rem; color: var(--text-main); margin-bottom: 2rem;">Contact Us</h2>
                        
                        <div class="contact-info-item">
                            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></div>
                            <div style="font-weight: 500; padding-top: 0.5rem;">contact@wework-consulting.com</div>
                        </div>

                        <div class="contact-info-item">
                            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></div>
