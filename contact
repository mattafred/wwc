<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact & Réservation - WeWork Consulting</title>
    <meta name="description" content="Contactez-nous pour réserver une consultation ou envoyer une demande.">
    <link rel="stylesheet" href="css/style.css">
    <style>
        .page-header { padding: 4rem 0 2rem; border-bottom: 1px solid var(--bg-alt); }
        .page-header h1 { color: var(--text-main); margin-bottom: 1rem; font-size: 2.5rem; }
        
        .contact-card {
            background: white; border: 1px solid var(--bg-alt); border-radius: var(--radius-lg); padding: 2.5rem;
            box-shadow: var(--shadow-md); margin-top: 2rem; margin-bottom: 4rem;
        }

        .contact-info-item { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem; }
        .contact-icon { color: var(--primary); background: var(--bg-subtle); padding: 0.75rem; border-radius: var(--radius-md); }
        
        .map-wrapper { margin-top: 2rem; border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--bg-alt); height: 250px; }
        .map-wrapper iframe { width: 100%; height: 100%; border: none; }

        .booking-section { border: 1px solid var(--bg-alt); border-radius: var(--radius-md); padding: 1.5rem; margin-bottom: 2rem; }
        .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.25rem; text-align: center; font-size: 0.875rem; }
        .calendar-day-header { color: var(--text-muted); font-weight: 500; padding: 0.25rem; }
        .calendar-day { padding: 0.5rem; border-radius: var(--radius-full); cursor: pointer; transition: var(--transition-normal); }
        .calendar-day:hover { background: var(--bg-subtle); }
        .calendar-day.selected { background: var(--primary); color: white; border-radius: 50%; }
        .calendar-day.muted { color: #CBD5E1; }

        .time-slots { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 1rem; }
        .time-slot { border: 1px solid var(--bg-alt); border-radius: var(--radius-md); padding: 0.5rem; text-align: center; cursor: pointer; font-size: 0.875rem; transition: var(--transition-normal); }
        .time-slot:hover { border-color: var(--primary-light); color: var(--primary-light); }
        .time-slot.selected { background: var(--primary-light); color: white; border-color: var(--primary-light); }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    </style>
</head>
<body class="section-bg">
