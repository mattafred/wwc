                            <div class="grid grid-cols-2" style="gap: 1.5rem;">
                                <!-- Calendrier statique pour le visuel -->
                                <div>
                                    <div class="calendar-header">
                                        <button style="border:none;background:none;cursor:pointer;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
