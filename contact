                        </div>

                        <div class="contact-info-item">
                            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></div>
                            <div style="font-weight: 500; padding-top: 0.5rem;">Rue du Lac d'Annecy, Les Berges du Lac,<br>1053 Tunis, Tunisie</div>
                        </div>

                        <div class="map-wrapper">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3192.93666506308!2d10.2285816!3d36.8437295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12fd35aa9430c7e5%3A0x67dbad94a82cdbb5!2sLes%20Berges%20du%20Lac%2C%20Tunis!5e0!3m2!1sfr!2stn!4v1700000000000!5m2!1sfr!2stn" allowfullscreen="" loading="lazy"></iframe>
